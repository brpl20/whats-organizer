meta {
  name: Download PDF
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/download-pdf
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  X-API-Key: {{apiKey}}
}

body:json {
  {
    "messages": [
      {
        "ID": 1,
        "Name": "User",
        "Date": "01/01/2025",
        "Time": "10:00",
        "Message": "Hello, this is a test message",
        "FileAttached": false,
        "IsApple": false
      }
    ],
    "isApple": false
  }
}
