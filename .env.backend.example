# Backend shared environment variables
# FLASK_PORT, RMQ_HOST, RMQ_PORT are set per-container in docker-compose.yml — do NOT set them here

# Flask
FLASK_ENV=prod
HOST=0.0.0.0

# Domain
DOMAIN=api.whatsorganizer.com.br
PUBLIC_API_URL=https://api.whatsorganizer.com.br
PUBLIC_FRONT_URL=https://whatsorganizer.com.br
PUBLIC_MAX_UPLOAD_MB=100

# Whisper / Transcription
WHISPER=sk-proj-xxx
WHISPER_GROQ=gsk_xxx
WHISPER_LANG=pt

# API Keys (comma-separated, leave empty for open access)
API_KEYS=
